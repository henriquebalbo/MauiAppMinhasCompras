<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="Lista de Compras" BackgroundColor="Bisque" >

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1" />
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked"/>
    </ContentPage.ToolbarItems>

    <VerticalStackLayout Spacing="15" Padding="30">
        
        <!-- Desenvolvendo o mecanismo de busca para pesquisar os produtos cadastrados -->
        <SearchBar x:Name="txt_search"
                   Placeholder="Pesquisando Produtos"
                   TextChanged="txt_search_TextChanged"/>
        <!-- adiconar o evento textchanged - novo manipulador de eventos -->

        <!-- O cabeçalho deve ser definido usando a propriedade Header diretamente no ListView -->
        <ListView x:Name="lst_produtos" ItemSelected="lst_produtos_ItemSelected">
            <ListView.Header>
                <Grid ColumnDefinitions="*, *, *, *, *">
                    <Label Grid.Column="0" Text="ID"/>
                    <Label Grid.Column="1" Text="Nome do produto" />
                    <Label Grid.Column="2" Text="Preço" />
                    <Label Grid.Column="3" Text="Quantidade" />
                    <Label Grid.Column="4" Text="Total" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <!-- uso para visualizar os dados-->
                <DataTemplate>
                    <!-- equivalente de uma TR na table -->
                    <ViewCell>
                        <!--ver o conteúdo dentro da listview  -->
                        <ViewCell.ContextActions>
                            <!--ações de contexto-->
                            <MenuItem Text="Remover" Clicked="MenuItem_Clicked"/>
                        </ViewCell.ContextActions>
                        <Grid ColumnDefinitions="*, *, *, *, *">
                            <Label Grid.Column="0" Text="{Binding Id}" />
                            <!-- chamando as propriedades da classe Model  -->
                            <Label Grid.Column="1" Text="{Binding Descricao}"/>
                            <Label Grid.Column="2" Text="{Binding Preco}" />
                            <Label Grid.Column="3" Text="{Binding Quantidade}" />
                            <Label Grid.Column="4" Text="{Binding Total}"/>
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <!-- gerar uma lista para o usuário - Alterada na Agenda 5- criando novo evento - símbolo do Raio -->
        
    </VerticalStackLayout>
</ContentPage>